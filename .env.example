# Microsoft cloud sync (OneDrive/SharePoint).
# Copy this file to ".env" and fill in the values from your Azure app registration.
# See README → "Cloud sync" for how to get them.

MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Optional: lock to your org's tenant id (default "common" = work or personal accounts).
# MS_TENANT=

# Optional: where live deck files are written (default ~/Documents/Figma Decks).
# DECKS_OUTPUT_DIR=

# Hosting: public HTTPS origin Figma can reach, to enable instant webhook refresh.
# Set this to your deployed URL (e.g. https://figma-deck.yourcompany.com).
# Leave empty for local desktop use (decks fall back to the daily refresh).
# WEBHOOK_BASE_URL=
